# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# In Supabase: Project Settings -> Database -> Connection string -> URI.
# Use the "Connection pooling" (port 6543) string for DATABASE_URL and the
# direct (port 5432) string for DIRECT_URL so `prisma migrate`/`db push` work.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/papertrader?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/papertrader?schema=public"

# ---------------------------------------------------------------------------
# NextAuth
# Generate a secret with: openssl rand -base64 32
# NEXTAUTH_URL is your site URL (http://localhost:3000 in dev).
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# (and https://YOUR_DOMAIN/api/auth/callback/google for production)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Market data (Finnhub) — free key at https://finnhub.io
# If left blank, the app falls back to a built-in simulated price engine so
# everything still works for local demos.
# ---------------------------------------------------------------------------
FINNHUB_API_KEY=""
